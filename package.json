{
  "name": "munchies-astro-cf",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "typegen": "turbo run typegen",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "turbo": "^2.7.5",
    "typescript": "5.9.2",
    "ultracite": "7.0.12"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "pnpm": {
    "neverBuiltDependencies": [
      "msgpackr-extract"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "@tinloof/astro-prefetch>astro": "7",
        "@tinloof/astro-ios-backnav-fix>astro": "7"
      }
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx,astro}": [
      "pnpm dlx ultracite fix"
    ]
  }
}
